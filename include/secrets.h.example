/*
 * secrets.h.example - Chibi StackChan (ATOMS3R)
 *
 * Copy this file to "secrets.h" (same folder) and fill in your own values.
 * secrets.h is git-ignored so your keys never get committed.
 *
 *   cp include/secrets.h.example include/secrets.h
 *
 * これらは NVS が空のときの初期値としてのみ使われます。
 * 実運用では AP 設定ポータル (http://192.168.4.1) から NVS に保存できるので、
 * このファイルが無くても (空のままでも) 運用できます。
 */
#pragma once

// --- Wi-Fi ---
#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASS "YOUR_WIFI_PASSWORD"

// --- AI services ---
// Google Gemini API key (LLM / conversation)
#define GEMINI_APIKEY "YOUR_GEMINI_API_KEY"

// OpenAI API key (used for Whisper speech-to-text)
#define OPENAI_APIKEY "YOUR_OPENAI_API_KEY"

// VoiceVox Web API key (text-to-speech)
#define VOICEVOX_APIKEY "YOUR_VOICEVOX_API_KEY"
